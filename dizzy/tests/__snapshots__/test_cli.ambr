    'libconfig.yaml': '''
      # Dizzy library configuration — assign runtimes to each element
      # Supported runtimes: python-uv | rust-cargo | typescript-npm
      
      procedures:
        extract_and_transform_recipe:
          runtimes: [python-uv]
      
      policies:
        index_recipe_on_ingest:
          runtimes: [python-uv]
      
      queries:
        get_recipe_text:
          runtimes: [python-uv]
        get_recipe:
          runtimes: [python-uv]
      
      projections:
        recipe_library:
          runtimes: [python-uv]
  
    ''',
  })
